mber","maximum":2000.0,"exclusiveMinimum":0.0,"title":"Building Depth M"},"standard":{"type":"string","title":"Standard","description":"Design standard: EN (Eurocode) or ASCE (US)","default":"EN"},"orography_factor":{"type":"number","maximum":2.0,"minimum":1.0,"title":"Orography Factor","default":1.0},"directional_factor":{"type":"number","maximum":1.0,"minimum":0.5,"title":"Directional Factor","default":1.0},"seasonal_factor":{"type":"number","maximum":1.0,"minimum":0.5,"title":"Seasonal Factor","default":1.0},"asce_exposure":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Asce Exposure","default":"C"},"asce_wind_speed_mph":{"anyOf":[{"type":"number","maximum":250.0,"exclusiveMinimum":0.0},{"type":"null"}],"title":"Asce Wind Speed Mph"}},"type":"object","required":["basic_wind_speed_ms","building_height_m","building_width_m","building_depth_m"],"title":"SiteInput","example":{"altitude_m":50,"basic_wind_speed_ms":28,"building_depth_m":20,"building_height_m":30,"building_width_m":40,"directional_factor":1.0,"orography_factor":1.0,"seasonal_factor":1.0,"standard":"EN","terrain_category":"II"}},"ValidationError":{"properties":{"loc":{"items":{"anyOf":[{"type":"string"},{"type":"integer"}]},"type":"array","title":"Location"},"msg":{"type":"string","title":"Message"},"type":{"type":"string","title":"Error Type"}},"type":"object","required":["loc","msg","type"],"title":"ValidationError"}},"securitySchemes":{"APIKeyHeader":{"type":"apiKey","in":"header","name":"X-API-Key"}}}}
